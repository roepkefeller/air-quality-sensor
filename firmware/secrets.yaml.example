# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is gitignored and will never be committed.

wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"
# 32-byte random key used to encrypt the Home Assistant native API connection.
# Generate one with: openssl rand -base64 32
# Or let ESPHome generate it automatically: esphome wizard air-quality-sensor.yaml
api_encryption_key: "your-base64-encryption-key"

# Password required for OTA firmware updates.
# Pick any string — you'll be prompted for this when flashing over-the-air.
ota_password: "your-ota-password"
